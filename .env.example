# LiveKit Cloud project credentials (from cloud.livekit.io → Settings → Keys)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Must match @server.rtc_session(agent_name=...) in main.py
LIVEKIT_AGENT_NAME=voice-agent

# LiveKit Inference — no separate Deepgram/OpenAI/Cartesia keys needed
STT_MODEL=deepgram/nova-3:en
LLM_MODEL=openai/gpt-4o-mini
TTS_MODEL=cartesia/sonic-3:9626c31c-bec5-4cca-baa8-f8ba9e84c8bc

PREEMPTIVE_GENERATION=true
DEBUG_MODE=false

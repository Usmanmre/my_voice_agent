# LiveKit Cloud project credentials (from cloud.livekit.io → Settings → Keys)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Must match @server.rtc_session(agent_name=...) in main.py
LIVEKIT_AGENT_NAME=voice-agent

# Provider API keys (billed directly by each provider)
DEEPGRAM_API_KEY=
OPENAI_API_KEY=

# Model settings (provider plugin format, not LiveKit Inference strings)
STT_MODEL=nova-3
STT_LANGUAGE=en
LLM_MODEL=gpt-4o-mini
TTS_MODEL=aura-2-thalia-en

PREEMPTIVE_GENERATION=true
DEBUG_MODE=false
